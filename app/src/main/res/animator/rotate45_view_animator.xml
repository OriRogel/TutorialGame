<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <objectAnimator
            android:propertyName="rotation"
            android:valueTo="90"
            android:duration="50"/>
    </item>

    <item>
        <objectAnimator
            android:propertyName="rotation"
            android:valueTo="45"
            android:duration="50"/>
    </item>
</selector>