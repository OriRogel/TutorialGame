<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="15dp"
    android:layoutDirection="ltr"
    android:background="@drawable/dialogbox_simple"
    android:orientation="vertical"
    android:padding="20dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_title"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="21sp"
            android:textColor="@color/black"
            android:fontFamily="@font/pixel_font"/>

        <TextView
            android:id="@+id/tv_message"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#606060"
            android:fontFamily="@font/pixel_font"
            android:textSize="15sp"/>

        <EditText
            android:id="@+id/et_input"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="17sp"
            android:layout_marginHorizontal="10dp"
            android:singleLine="true"
            android:fontFamily="@font/pixel_font"
            android:imeOptions="flagNoExtractUi"/>
    </LinearLayout>

    <!-- Container for Dual Buttons (Cancel/Continue) -->
    <LinearLayout
        android:id="@+id/layout_dual_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="5dp">

        <android.widget.Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:shadowDy="2"
            android:shadowRadius="1"
            android:shadowColor="@color/black"
            android:background="@drawable/button_dialog_selector"
            android:backgroundTint="@null"
            android:layout_weight="50"
            android:layout_marginStart="7dp"
            android:text="@string/cancel"
            android:fontFamily="@font/pixel_font"/>

        <android.widget.Button
            android:id="@+id/btn_continue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:shadowDy="2"
            android:shadowRadius="1"
            android:shadowColor="@color/black"
            android:background="@drawable/button_dialog_selector"
            android:backgroundTint="@null"
            android:layout_weight="50"
            android:layout_marginStart="7dp"
            android:text="@string/continue_"
            android:fontFamily="@font/pixel_font"/>
    </LinearLayout>

    <!-- Container for Single Button (Confirm/OK) -->
    <android.widget.Button
        android:id="@+id/btn_ok"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="70dp"
        android:visibility="gone"
        android:textColor="@color/white"
        android:shadowDy="2"
        android:shadowRadius="1"
        android:shadowColor="@color/black"
        android:background="@drawable/button_dialog_selector"
        android:backgroundTint="@null"
        android:text="@string/ok"
        android:fontFamily="@font/pixel_font" />

</androidx.appcompat.widget.LinearLayoutCompat>
